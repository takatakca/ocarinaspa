# ============================================================
# Ocarina Spa Québec — Environment variables for MochaHost
# Copy to .env (local) or set in cPanel "Environment Variables"
# ============================================================

# Node server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Lovable Cloud / Supabase backend (already provisioned)
SUPABASE_URL=https://jbdkvdowxwrwyuhglxgu.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY, never expose

# Build-time (Vite) — must be present at BUILD time, not runtime
VITE_SUPABASE_URL=https://jbdkvdowxwrwyuhglxgu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_PROJECT_ID=jbdkvdowxwrwyuhglxgu

# AI Gateway (optional, only if AI features are used)
LOVABLE_API_KEY=

# Google Maps (browser, restrict to ocarinaspa.ca in Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key
